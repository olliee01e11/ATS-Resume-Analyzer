# Docker Environment Configuration
# Copy this file to .env.docker and fill in your actual values.
# .env.docker is ignored by git and should stay local.

PORT=3000
APP_HOST_PORT=3000

# AI Service Configuration
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here
# Optional legacy alias
OPENAI_API_KEY=
BASE_URL=https://openrouter.ai/api/v1
ANALYSIS_MODEL=google/gemini-2.0-flash-exp:free

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Secrets
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-a-different-strong-random-secret-in-production

# Database Configuration
DATABASE_URL=file:./data/dev.db
DATABASE_PROVIDER=sqlite
RESET_DATABASE_ON_START=0

# Queue Configuration
QUEUE_PROVIDER=memory

# Optional HTTP metadata
HTTP_REFERER=https://your-domain.com
X_TITLE=ATS Analyzer
