PORT=3001
OPENROUTER_API_KEY=sk-or-*****
# Optional legacy alias
OPENAI_API_KEY=
BASE_URL=https://openrouter.ai/api/v1
ANALYSIS_MODEL=google/gemini-2.0-flash-exp:free
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173

HTTP_REFERER=https://your-site.com
X_TITLE=ATS Analyzer


# DATABASE_PROVIDER="mongodb"
# DATABASE_URL="mongodb+srv://db_user:db_password@cluster0.mongodb.net/MY_ATS_DATABASE?retryWrites=true&w=majority"

DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"


JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Job Queue Configuration
# QUEUE_PROVIDER can be 'redis' or in-memory (default)
# In development: uses in-memory by default
# In production: uses Redis (set explicitly)
QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379
NODE_ENV=development
